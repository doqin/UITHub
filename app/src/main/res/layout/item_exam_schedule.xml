<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="7dp"
    android:orientation="horizontal">

    <!-- Color Accent Bar -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_schedule_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="@drawable/bg_schedule_card"
        android:elevation="1dp">

        <!-- Course Code & Exam Shift Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvCourseCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INT1001"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExamShift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_period_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Ca 1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Class Code -->
        <TextView
            android:id="@+id/tvClassCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CNTT1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <!-- Exam Date & Weekday -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="@string/clock_icon"
                android:layout_marginEnd="6dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvExamDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thứ Sáu 20/12"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_clock"
                android:contentDescription="@string/clock_icon"
                android:layout_marginEnd="6dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvExamTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="07:00 - 08:45"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Room Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location_pin"
                android:contentDescription="@string/location_icon"
                android:layout_marginEnd="6dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvExamRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng A1.201"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginBottom="8dp" />

        <!-- Status & Days Remaining Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvExamStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="UPCOMING"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/success_green"
                android:background="@drawable/bg_period_badge" />

            <TextView
                android:id="@+id/tvDaysRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="5 ngày nữa"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>