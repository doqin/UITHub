<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    tools:context=".AnnouncementFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_segmented_bar"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabTextColor="?attr/colorOnSurfaceVariant"
            app:tabSelectedTextColor="?attr/colorOnPrimaryContainer"
            app:tabIndicatorHeight="0dp"
            app:tabBackground="@drawable/tab_indicator"
            app:tabRippleColor="@android:color/transparent"
            app:tabPaddingStart="8dp"
            app:tabPaddingEnd="8dp"
            app:tabContentStart="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReloadAnnouncements"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/reload_announcements"
            app:icon="@drawable/ic_refresh_24"
            app:iconTint="?attr/colorPrimary" />
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="?attr/colorSurface"
        android:layout_weight="1">


        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
